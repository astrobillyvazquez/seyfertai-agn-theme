        "foreground": "#A5B4FC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Class / type / interface / enum",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.struct",
        "entity.name.trait",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "meta.type.declaration",
        "meta.interface entity.name",
        "meta.class entity.name"
      ],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },
    {
      "name": "Primitive types",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "support.type.object",
