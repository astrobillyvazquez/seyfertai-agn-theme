  ],
  "semanticTokenColors": {
    "class": "#7DD3FC",
    "interface": "#7DD3FC",
    "enum": "#7DD3FC",
    "typeParameter": "#7DD3FC",
    "type": "#7DD3FC",
    "struct": "#7DD3FC",
    "namespace": "#7DD3FC",
    "function": "#A5B4FC",
    "method": "#A5B4FC",
    "macro": "#E5B867",
    "variable": "#E5E9F2",
    "variable.readonly": "#C4B5FD",
    "variable.defaultLibrary": { "foreground": "#FB7185", "italic": true },
    "parameter": { "foreground": "#F5D8A3", "italic": true },
    "property": "#A5B4FC",
    "property.readonly": "#C4B5FD",
    "enumMember": "#C4B5FD",
    "event": "#F472B6",
    "decorator": { "foreground": "#E5B867", "italic": true },
    "selfKeyword": { "foreground": "#FB7185", "italic": true },
    "keyword": { "foreground": "#F472B6", "bold": true },
    "operator": "#94A3B8",
    "string": "#E5B867",
    "number": "#C4B5FD",
    "regexp": "#FB7185",
    "comment": { "foreground": "#5B6478", "italic": true },
    "*.deprecated": { "strikethrough": true }
  }
}
