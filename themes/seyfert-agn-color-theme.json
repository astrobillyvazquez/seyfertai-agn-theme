    "charts.green": "#4ADE80",
    "charts.purple": "#C4B5FD",

    "//": "────────── Text colors ──────────",
    "textLink.foreground": "#A5B4FC",
    "textLink.activeForeground": "#E5B867",
    "textBlockQuote.background": "#0E1424",
    "textBlockQuote.border": "#818CF8",
    "textCodeBlock.background": "#060A14",
    "textPreformat.foreground": "#E5B867",
    "textSeparator.foreground": "#242D47",

    "//": "────────── Git editor gutter markers ──────────",
    "editorMarkerNavigation.background": "#0E1424",
    "editorMarkerNavigationError.background": "#F43F5E",
    "editorMarkerNavigationWarning.background": "#E5B867",
    "editorMarkerNavigationInfo.background": "#7DD3FC",

    "//": "────────── Banner / toolbar ──────────",
    "banner.background": "#0E1424",
    "banner.foreground": "#E5E9F2",
    "banner.iconForeground": "#A5B4FC",
    "toolbar.hoverBackground": "#6366F11F",
    "toolbar.activeBackground": "#6366F133"
  },
  "tokenColors": [
    {
      "name": "Base text",
      "scope": ["source", "text"],
      "settings": {
        "foreground": "#E5E9F2"
      }
    },
    {
      "name": "Comments — nebula dust",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#5B6478",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comments",
      "scope": ["comment.block.documentation", "comment.line.documentation"],
      "settings": {
        "foreground": "#7B869B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings — AGN gold (sacred)",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#E5B867"
      }
    },
    {
      "name": "String punctuation",
      "scope": ["punctuation.definition.string"],
      "settings": {
        "foreground": "#E5B867"
      }
    },
    {
      "name": "Template literal interpolation",
      "scope": ["punctuation.definition.template-expression", "meta.template.expression", "punctuation.section.embedded"],
      "settings": {
        "foreground": "#F472B6"
      }
    },
    {
      "name": "Escape characters / regex special",
      "scope": ["constant.character.escape", "constant.other.placeholder"],
      "settings": {
        "foreground": "#FB7185"
      }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp", "string.regex"],
      "settings": {
        "foreground": "#FB7185"
      }
    },
    {
      "name": "Numbers / constants / boolean",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.infinity",
        "constant.language.nan",
        "constant.other"
      ],
      "settings": {
        "foreground": "#C4B5FD"
      }
    },
    {
      "name": "Keywords — plasma pink",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.loop",
        "keyword.control.conditional",
        "keyword.control.return",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default",
        "keyword.control.new",
        "keyword.control.delete",
        "keyword.control.trycatch",
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#F472B6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators — dust gray (recedes)",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.bitwise",
        "keyword.operator.accessor",
        "keyword.operator.type",
        "keyword.operator.relational"
      ],
      "settings": {
        "foreground": "#94A3B8",
        "fontStyle": ""
      }
    },
    {
      "name": "Arrow / fat arrow",
      "scope": ["storage.type.function.arrow", "keyword.operator.arrow"],
      "settings": {
        "foreground": "#F472B6"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.section",
        "meta.brace",
        "punctuation.definition.parameters",
        "punctuation.definition.arguments",
        "punctuation.definition.block"
      ],
      "settings": {
        "foreground": "#94A3B8"
      }
    },
    {
      "name": "Storage — let/const/var/function/class",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier",
        "storage.type.class",
        "storage.type.function",
        "storage.type.interface",
        "storage.type.enum",
        "storage.type.namespace",
        "storage.type.type",
        "storage.type.import",
        "storage.type.export"
      ],
      "settings": {
        "foreground": "#F472B6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function / method name",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "meta.function entity.name.function",
